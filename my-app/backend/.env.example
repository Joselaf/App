# Tuya Cloud API credentials
TUYA_API_REGION=eu
TUYA_API_KEY=c8uhx3vs89grhea8mg7p
TUYA_API_SECRET=7221603a3b754d8b89b30c8dc9114b0d
# A device ID in your project (used by tinytuya Cloud auth)
TUYA_API_DEVICE_ID=your_primary_device_id

# Polling config (in seconds, lower = more real-time)
TUYA_POLL_INTERVAL_SECONDS=5

# If false, monitor all devices in the Tuya project.
# Set true only if you want to limit monitoring to TUYA_DEVICE_IDS.
TUYA_ONLY_SELECTED_DEVICES=false

# Comma-separated device IDs to monitor
TUYA_DEVICE_IDS=device_id_1,device_id_2

# Optional path to custom rules file
# TUYA_RULES_FILE=backend/device_rules.json
